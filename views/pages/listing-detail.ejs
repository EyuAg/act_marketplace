<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container">
    <a href="/listings" style="display: inline-flex; align-items: center; gap: 0.5rem; margin-bottom: 1.5rem; font-weight: 600; color: var(--primary-light);">
        &larr; Back to Browse
    </a>

    <div class="detail-grid">
        <!-- Left: Image Gallery -->
        <div class="detail-gallery">
            <% 
                let gallery = [];
                if (listing.images && listing.images.length) gallery = listing.images;
                else if (listing.image_url) {
                    try { const parsed = JSON.parse(listing.image_url); gallery = Array.isArray(parsed) ? parsed : [listing.image_url]; } catch(e) { gallery = [listing.image_url]; }
                }
            %>
            <% if (gallery.length) { %>
                <% gallery.forEach((img, idx) => { %>
                    <img src="<%= img %>" alt="<%= listing.title %> - <%= idx+1 %>">
                <% }) %>
            <% } else { %>
                <div class="listing-placeholder">📦</div>
            <% } %>
        </div>
        
        <!-- Right: Information & Action -->
        <div class="detail-info">
            <div class="detail-badges">
                <span class="detail-badge cat"><%= listing.category %></span>
                <span class="detail-badge cond"><%= listing.condition %></span>
            </div>
            
            <h1 class="detail-title"><%= listing.title %></h1>
            
            <div class="detail-price">ETB <%= parseFloat(listing.price).toFixed(2) %></div>
            
            <div class="detail-description">
                <h3>Description</h3>
                <p><%= listing.description %></p>
            </div>
            
            <!-- Contact Seller Box -->
            <% if (user && user.id !== listing.user_id) { %>
                <div class="seller-box">
                    <h3>✉️ Contact Seller</h3>
                    <p>Interested in this item? Reach out to the seller directly via email:</p>
                    <p style="font-weight: 700; margin-top: 0.5rem; color: var(--primary);">
                        <a href="mailto:<%= listing.seller_email %>"><%= listing.seller_email %></a>
                    </p>
                </div>
            <% } else if (!user) { %>
                <div class="seller-box" style="text-align: center;">
                    <p><a href="/login" style="font-weight: 700; text-decoration: underline;">Login</a> to contact the seller.</p>
                </div>
            <% } %>
            
            <!-- Owner Actions -->
            <% const listingId = listing.id || listing.listing_id || listing._id; %>
            <% if (user && user.id === listing.user_id) { %>
                <div style="margin-top: auto; display: flex; gap: 1rem; border-top: 1px solid var(--border-color); padding-top: 1.5rem;">
                    <a href="/my-listings/edit/<%= listingId %>" class="btn btn-secondary" style="flex: 1; text-align: center;">Edit Details</a>
                    <a href="/my-listings/delete/<%= listingId %>" class="btn btn-danger" style="flex: 1; text-align: center;" onclick="return confirm('Are you sure you want to delete this listing?')">Delete Item</a>
                </div>
            <% } %>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>