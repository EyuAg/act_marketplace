<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container">
    <div class="form-container">
        <h2>Choose a new password</h2>
        <p>Reset links expire after 1 hour</p>

        <% if (error) { %>
            <div class="alert alert-error">
                <span><%= error %></span>
            </div>
        <% } %>

        <% if (success) { %>
            <div class="alert alert-success">
                <span><%= success %></span>
            </div>
        <% } %>

        <% if (token) { %>
            <form method="POST" action="/reset-password/<%= token %>">
                <div class="form-group">
                    <label for="password">New Password</label>
                    <input type="password" name="password" id="password" required minlength="8">
                </div>

                <div class="form-group">
                    <label for="confirm_password">Confirm Password</label>
                    <input type="password" name="confirm_password" id="confirm_password" required minlength="8">
                </div>

                <button type="submit" class="btn btn-primary btn-full" style="margin-top: 1rem;">Update Password</button>
            </form>
        <% } %>

        <p style="margin-top: 1.5rem; text-align: center; font-size: 0.9rem;">
            <a href="/login" style="font-weight: 600; color: var(--secondary);">Back to login</a>
        </p>
    </div>
</div>

<%- include('../partials/footer') %>
