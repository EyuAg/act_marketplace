<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h2 style="font-size: 2.2rem; color: var(--primary-dark);">My Listings</h2>
            <p style="color: var(--text-muted); margin-top: 0.25rem;">Manage the items you have listed for sale</p>
        </div>
        <a href="/my-listings/create" class="btn btn-secondary">+ Add New Item</a>
    </div>

    <% if (listings.length === 0) { %>
        <div style="text-align: center; padding: 5rem; background: var(--bg-card); border-radius: var(--radius-md); box-shadow: var(--shadow-sm); border: 1px solid var(--border-color);">
            <div style="font-size: 4rem; margin-bottom: 1rem;">🏷️</div>
            <h3 style="margin-bottom: 0.5rem;">No Listings Yet</h3>
            <p style="color: var(--text-muted); margin-bottom: 1.5rem;">You haven't listed any items for sale yet.</p>
            <a href="/my-listings/create" class="btn btn-primary">List Your First Item</a>
        </div>
    <% } else { %>
        <div class="listings-grid">
            <% listings.forEach(listing => { %>
                <div class="listing-card">
                    <div class="listing-image-container">
                        <% 
                            let primaryImage = null;
                            if (listing.images && listing.images.length) primaryImage = listing.images[0];
                            else if (listing.image_url) {
                                try { const parsed = JSON.parse(listing.image_url); primaryImage = Array.isArray(parsed) ? parsed[0] : listing.image_url; } catch(e) { primaryImage = listing.image_url; }
                            }
                        %>
                        <% if (primaryImage) { %>
                            <img src="<%= primaryImage %>" alt="<%= listing.title %>" class="listing-image" loading="lazy">
                        <% } else { %>
                            <div class="listing-placeholder">📦</div>
                        <% } %>
                        <span class="listing-badge"><%= listing.category %></span>
                        <span class="listing-badge condition" style="background: <%= listing.status === 'active' ? 'var(--accent)' : 'var(--danger)' %>;">
                            <%= listing.status.toUpperCase() %>
                        </span>
                    </div>
                    
                    <div class="listing-content">
                        <h3 class="listing-title"><%= listing.title %></h3>
                        <p class="listing-price">ETB <%= parseFloat(listing.price).toFixed(2) %></p>
                        <p class="listing-seller" style="font-size: 0.8rem; margin-bottom: 0.5rem;">Condition: <%= listing.condition %></p>
                        
                        <div style="margin-top: auto; display: flex; gap: 0.5rem; border-top: 1px solid var(--border-color); padding-top: 1rem;">
                            <% const listingId = listing.id || listing.listing_id || listing._id; %>
                        <a href="/listings/<%= listingId %>" class="btn btn-primary" style="flex: 1; padding: 0.4rem 0.8rem; font-size: 0.85rem; text-align: center;">View</a>
                            <a href="/my-listings/edit/<%= listingId %>" class="btn btn-secondary" style="flex: 1; padding: 0.4rem 0.8rem; font-size: 0.85rem; text-align: center;">Edit</a>
                            <a href="/my-listings/delete/<%= listingId %>" class="btn btn-danger" style="flex: 1; padding: 0.4rem 0.8rem; font-size: 0.85rem; text-align: center;" onclick="return confirm('Are you sure you want to delete this listing?')">Delete</a>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>
</div>

<%- include('../partials/footer') %>