<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container">
    <div class="form-container">
        <h2>Reset your password</h2>
        <p>Enter your ACT email address to receive a time-limited reset link</p>

        <% if (error) { %>
            <div class="alert alert-error">
                <span><%= error %></span>
            </div>
        <% } %>

        <% if (success) { %>
            <div class="alert alert-success">
                <span><%= success %></span>
            </div>
        <% } %>

        <form method="POST" action="/forgot-password">
            <div class="form-group">
                <label for="email">ACT Email Address</label>
                <input type="email" name="email" id="email" placeholder="email@act.edu" required>
            </div>

            <button type="submit" class="btn btn-primary btn-full" style="margin-top: 1rem;">Send Reset Link</button>
        </form>

        <p style="margin-top: 1.5rem; text-align: center; font-size: 0.9rem;">
            Remembered your password? <a href="/login" style="font-weight: 600; color: var(--secondary);">Back to login</a>
        </p>
    </div>
</div>

<%- include('../partials/footer') %>
