<%- include('../partials/header') %>
    <%- include('../partials/navbar') %>

        <div class="browse-container">
            <div class="container">
                <div class="browse-header">
                    <h1>Browse Listings</h1>
                    <p>Find what you need from fellow ACT students</p>
                </div>

                <div class="browse-layout">
                    <!-- Filter Sidebar -->
                    <%- include('../partials/sidebar') %>

                        <!-- Results Section -->
                        <div class="results-section">
                            <div class="results-header">
                                <div class="results-count">
                                    <i class="fas fa-shopping-bag"></i>
                                    <%= listings.length %> items found
                                </div>

                                <!-- Sort Options -->
                                <div class="sort-options">
                                    <label>Sort by:</label>
                                    <select id="sort-by">
                                        <option value="newest">Newest First</option>
                                        <option value="oldest">Oldest First</option>
                                        <option value="price_low">Price: Low to High</option>
                                        <option value="price_high">Price: High to Low</option>
                                    </select>
                                </div>
                            </div>

                            <!-- Results Grid -->
                            <% if (listings.length===0) { %>
                                <div class="no-results">
                                    <i class="fas fa-search"></i>
                                    <h3>No listings found</h3>
                                    <p>Try adjusting your search or filter criteria</p>
                                    <a href="/listings" class="btn-primary">Clear All Filters</a>
                                </div>
                                <% } else { %>
                                    <div class="listings-grid">
            <% listings.forEach(listing => { %>
                <%- include('../partials/listing-card', { listing: listing }) %>
            <% }) %>
        </div>
                                    <% } %>
                        </div>
                </div>
            </div>
        </div>

        <%- include('../partials/footer') %>

            <style>
                .browse-container {
                    padding: 2rem 0;
                    background: #f8fafc;
                    min-height: calc(100vh - 200px);
                }

                .browse-header {
                    text-align: center;
                    margin-bottom: 2rem;
                }

                .browse-header h1 {
                    font-size: 2rem;
                    color: #1E3A5F;
                }

                .browse-layout {
                    display: flex;
                    gap: 2rem;
                }

                .filter-sidebar {
                    width: 280px;
                    background: white;
                    padding: 1.5rem;
                    border-radius: 12px;
                    position: sticky;
                    top: 100px;
                    height: fit-content;
                    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
                }

                .filter-sidebar h3 {
                    margin-bottom: 1.5rem;
                    color: #1E3A5F;
                }

                .filter-group {
                    margin-bottom: 1.5rem;
                }

                .filter-group label {
                    display: block;
                    margin-bottom: 0.5rem;
                    font-weight: 600;
                    color: #334155;
                }

                .filter-group input,
                .filter-group select {
                    width: 100%;
                    padding: 0.5rem;
                    border: 1px solid #e2e8f0;
                    border-radius: 8px;
                }

                .price-range {
                    display: flex;
                    gap: 0.5rem;
                    align-items: center;
                }

                .price-range input {
                    flex: 1;
                }

                .condition-options {
                    display: flex;
                    flex-wrap: wrap;
                    gap: 0.5rem;
                }

                .condition-options label {
                    display: flex;
                    align-items: center;
                    gap: 0.25rem;
                    font-weight: normal;
                    cursor: pointer;
                }

                .btn-primary {
                    width: 100%;
                    background: #1E3A5F;
                    color: white;
                    padding: 0.75rem;
                    border: none;
                    border-radius: 8px;
                    cursor: pointer;
                    margin-bottom: 0.5rem;
                }

                .clear-filters {
                    display: block;
                    text-align: center;
                    color: #ef4444;
                    text-decoration: none;
                    font-size: 0.875rem;
                }

                .results-section {
                    flex: 1;
                }

                .results-header {
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    margin-bottom: 1.5rem;
                    padding: 1rem;
                    background: white;
                    border-radius: 8px;
                }

                .results-count {
                    font-weight: 600;
                    color: #334155;
                }

                .sort-options select {
                    padding: 0.5rem;
                    border: 1px solid #e2e8f0;
                    border-radius: 8px;
                }

                .listings-grid {
                    display: grid;
                    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
                    gap: 1.5rem;
                }

                .listing-card {
                    background: white;
                    border-radius: 12px;
                    overflow: hidden;
                    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
                    transition: transform 0.3s, box-shadow 0.3s;
                }

                .listing-card:hover {
                    transform: translateY(-4px);
                    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
                }

                .listing-image {
                    height: 200px;
                    background: #f1f5f9;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                }

                .listing-image img {
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                }

                .no-image {
                    font-size: 3rem;
                    color: #94a3b8;
                }

                .listing-info {
                    padding: 1rem;
                }

                .listing-info h3 {
                    margin-bottom: 0.5rem;
                    font-size: 1rem;
                }

                .listing-info h3 a {
                    color: #1e293b;
                    text-decoration: none;
                }

                .price {
                    font-size: 1.25rem;
                    font-weight: bold;
                    color: #1E3A5F;
                    margin-bottom: 0.5rem;
                }

                .seller,
                .condition,
                .category {
                    font-size: 0.875rem;
                    color: #64748b;
                    margin-bottom: 0.25rem;
                }

                .btn-view {
                    display: inline-block;
                    margin-top: 0.75rem;
                    color: #f4a261;
                    text-decoration: none;
                    font-weight: 600;
                }

                .no-results {
                    text-align: center;
                    padding: 4rem;
                    background: white;
                    border-radius: 12px;
                }

                .no-results i {
                    font-size: 4rem;
                    color: #cbd5e1;
                    margin-bottom: 1rem;
                }

                @media (max-width: 768px) {
                    .browse-layout {
                        flex-direction: column;
                    }

                    .filter-sidebar {
                        width: 100%;
                        position: static;
                    }

                    .listings-grid {
                        grid-template-columns: 1fr;
                    }
                }
            </style>

            <script>
                // Sorting functionality
                document.getElementById('sort-by')?.addEventListener('change', function () {
                    const sortValue = this.value;
                    const grid = document.querySelector('.listings-grid');
                    const cards = Array.from(grid.querySelectorAll('.listing-card'));

                    cards.sort((a, b) => {
                        const priceA = parseFloat(a.dataset.price);
                        const priceB = parseFloat(b.dataset.price);
                        const dateA = new Date(a.dataset.date);
                        const dateB = new Date(b.dataset.date);

                        if (sortValue === 'price_low') return priceA - priceB;
                        if (sortValue === 'price_high') return priceB - priceA;
                        if (sortValue === 'newest') return dateB - dateA;
                        if (sortValue === 'oldest') return dateA - dateB;
                        return 0;
                    });

                    cards.forEach(card => grid.appendChild(card));
                });
            </script>