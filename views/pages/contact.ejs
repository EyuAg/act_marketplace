<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container">
    <div class="form-container" style="max-width: 800px; padding: 3rem;">
        <h2 style="font-size: 2.4rem; color: var(--primary-dark); margin-bottom: 1rem; text-align: left;">Contact Us</h2>
        <p style="text-align: left; margin-bottom: 2rem;">Have questions, feedback, or need help? Get in touch with the ACT Market team.</p>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; text-align: left; margin-bottom: 3rem;">
            <!-- Contact Details -->
            <div>
                <h3 style="font-size: 1.2rem; color: var(--primary); margin-bottom: 0.75rem;">Support Desk</h3>
                <p style="font-size: 1rem; color: var(--text-main); margin-bottom: 1.5rem; line-height: 1.6;">
                    For account issues, listings moderation, or general technical support, reach out to our administration team:<br>
                    <strong>Email:</strong> <a href="mailto:support@act.edu">support@act.edu</a><br>
                    <strong>Office:</strong> Block B, Room 204
                </p>
                
                <h3 style="font-size: 1.2rem; color: var(--primary); margin-bottom: 0.75rem;">College Campus</h3>
                <p style="font-size: 1rem; color: var(--text-muted); line-height: 1.6;">
                    American College of Technology (ACT)<br>
                    Addis Ababa, Ethiopia<br>
                    <strong>Website:</strong> <a href="https://www.act.edu" target="_blank">www.act.edu</a>
                </p>
            </div>
            
            <!-- Quick Form Placeholder or notes -->
            <div style="background: var(--bg-app); padding: 1.5rem; border-radius: var(--radius-md); border: 1px solid var(--border-color);">
                <h3 style="font-size: 1.1rem; color: var(--primary-dark); margin-bottom: 0.75rem;">Safety Tip 🛡️</h3>
                <p style="font-size: 0.95rem; color: var(--text-main); line-height: 1.6; margin-bottom: 1rem;">
                    For your security, always meet in public, well-lit spaces on the ACT campus (such as the campus library, cafeteria, or main courtyard) when trading items.
                </p>
                <p style="font-size: 0.95rem; color: var(--text-main); line-height: 1.6;">
                    Never share your bank credentials, and verify the items carefully before sending payment.
                </p>
            </div>
        </div>

        <div style="text-align: center; border-top: 1px solid var(--border-color); padding-top: 2rem;">
            <a href="/" class="btn btn-primary">Back to Home Page</a>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
